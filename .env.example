# Copy to `.env` and set real secrets. Any value left unset falls back to the
# default defined in docker-compose.yml, so `.env` is optional for local use.
# Docker Compose loads `.env` automatically from this directory.

# Database password for the `kimai` MySQL user (used by both the DB and the app).
KIMAI_DB_PASSWORD=changeme_db_pw

# MariaDB root password.
KIMAI_DB_ROOT_PASSWORD=changeme_root_pw

# Initial Kimai admin account password.
KIMAI_ADMIN_PASSWORD=changeme_admin_pw
